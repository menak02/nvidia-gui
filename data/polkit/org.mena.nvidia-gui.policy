<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1.0/policyconfig-1.dtd">
<policyconfig>
  <vendor>mena</vendor>
  <vendor_url>https://github.com/mena/nvidia-gui</vendor_url>

  <action id="org.mena.nvidia-gui.write-kernel-params">
    <!-- Shown in the authentication dialog. -->
    <description>NVIDIA-GUI: manage NVIDIA kernel-module parameters</description>
    <message>Writing NVreg_* settings to /etc/modprobe.d/nvidia-gui.conf (applied at next boot) requires authentication.</message>
    <icon_name>nvidia-gui</icon_name>
    <defaults>
      <!-- an active local user can authenticate with their own password; the
           keep flag remembers it briefly so repeated saves don't reprompt. -->
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_self_keep</allow_active>
    </defaults>
    <!-- pin this action id to our dedicated helper so pkexec of it uses *our*
         dialog rather than the generic org.freedesktop.policykit.exec prompt. -->
    <annotate key="org.freedesktop.policykit.exec.path">/usr/libexec/nvidia-gui-apply-modprobe</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>
</policyconfig>
