// nvidia-gui polkit rule.
//
// The .policy file already defaults allow_active -> auth_self_keep for
// org.mena.nvidia-gui.write-kernel-params. This rule additionally lets an
// active, local member of the "wheel" group apply kernel-module params WITHOUT
// a prompt on a typical single-user CachyOS/Arch box. To require a password
// instead, delete this file (the .policy default still asks auth_self_keep) or
// change YES -> AUTH_SELF_KEEP.

polkit.addRule(function(action, subject) {
    if (action.id === "org.mena.nvidia-gui.write-kernel-params" &&
        subject.local && subject.active && subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
